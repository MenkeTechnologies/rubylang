#compdef ruby
# Zsh completion for the rubyrs `ruby` binary.

_ruby() {
  local -a opts
  opts=(
    '*-e[execute a one-liner (repeatable)]:source'
    '*-I[prepend directory to $LOAD_PATH]:directory:_files -/'
    '*-r[require a library before running]:library'
    '-c[check syntax only]'
    '-w[turn on warnings]'
    '-W[set warning level]:level:(0 1 2)'
    '-d[set $DEBUG]'
    '--debug[set $DEBUG]'
    '-S[search $PATH for the script]'
    '-v[print version, then run in verbose mode]'
    '--repl[start the interactive REPL]'
    '--lsp[speak the Language Server Protocol over stdio]'
    '--dap[speak the Debug Adapter Protocol over stdio]'
    '--build[AOT-compile the script bytecode into the cache]'
    '--native[with --build: emit a standalone native executable]'
    '--dump-bytecode[print the lowered fusevm bytecode]'
    '--dump-tokens[print the lexer token stream]'
    '--dump-ast[print the parsed AST]'
    '--disasm[print a fusevm bytecode disassembly listing]'
    '-h[show help]'
    '--help[show help]'
    '--version[show version]'
    '*:Ruby script:_files -g "*.rb"'
  )
  _arguments -s $opts
}

_ruby "$@"
